{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lunote.app/schemas/plugin-catalog-index.v2.json",
  "title": "LunotePluginCatalogIndex",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "plugins"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "generatedAt": { "type": "string", "format": "date-time" },
    "minAppVersion": { "type": "string" },
    "catalogUrl": { "type": "string", "format": "uri" },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/PluginIndexEntry" }
    },
    "categories": {
      "type": "array",
      "items": { "$ref": "#/$defs/Category" }
    }
  },
  "$defs": {
    "LocalizedString": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      ]
    },
    "Category": {
      "type": "object",
      "required": ["id", "label"],
      "properties": {
        "id": { "type": "string" },
        "label": { "$ref": "#/$defs/LocalizedString" }
      }
    },
    "PluginIndexEntry": {
      "type": "object",
      "required": ["id", "name", "author", "tagline", "category", "icon", "latestVersion", "detailUrl"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
        "name": { "type": "string" },
        "author": { "type": "string" },
        "pluginType": { "type": "string" },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "platforms": { "type": "array", "items": { "type": "string" } },
        "requiresRestart": { "type": "boolean" },
        "experimental": { "type": "boolean" },
        "tagline": { "$ref": "#/$defs/LocalizedString" },
        "category": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "icon": { "type": "string", "format": "uri" },
        "latestVersion": { "type": "string" },
        "minAppVersion": { "type": "string" },
        "maxAppVersion": { "type": ["string", "null"] },
        "downloads": { "type": "integer", "minimum": 0 },
        "rating": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
        "featured": { "type": "boolean" },
        "verified": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date" },
        "detailUrl": { "type": "string" }
      }
    }
  }
}
